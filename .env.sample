# ─── AI Gateway Lab 환경 변수 ───
# deploy.sh 실행 후 자동 생성됩니다 (.env 파일)
# deploy.sh가 자동 입력하는 값 외에 Subscription Key만 수동 입력하세요.
# 나머지는 각 Lab에서 필요할 때 입력합니다.

# ═══════════════════════════════════════════════════════
# 필수 설정 (Lab 1~6 공통)
# ═══════════════════════════════════════════════════════

# APIM 설정 — deploy.sh가 자동 입력합니다
# 수동 확인: Azure Portal → API Management → Overview → Gateway URL
APIM_URL=https://<apim-name>.azure-api.net
# 수동 확인: Azure Portal → API Management → Overview → Name
APIM_NAME=<apim-name>
# 수동 확인: Azure Portal → 리소스 그룹 이름
RESOURCE_GROUP=rg-ai-gw-<suffix>

# APIM Subscription Key — 수동 입력 필요
# 경로: Azure Portal → API Management → APIs → Subscriptions
#       → Built-in all-access subscription → ··· → Show/hide keys → Primary key 복사
APIM_SUBSCRIPTION_KEY="<your-subscription-key>"

# API 설정
# DEPLOYMENT_NAME: Azure OpenAI에 배포된 모델 이름 (infra/modules/openai.bicep 참고)
DEPLOYMENT_NAME=gpt-4.1-nano
# APIM_API_NAME: APIM에 등록한 API 이름 (Portal → APIM → APIs에서 확인)
APIM_API_NAME=azure-openai

# ═══════════════════════════════════════════════════════
# Lab 4: 멀티 테넌트 테스트용 (선택사항)
# ═══════════════════════════════════════════════════════

# test-token-limit.ipynb의 1단계 셀 실행 시 자동 생성되어 출력됩니다.
# 출력된 Primary Key를 아래에 입력하세요.
# 수동 확인: Azure Portal → APIM → APIs → Subscriptions
#            → Sub: Request Limited / Sub: Token Limited → Show/hide keys
APIM_KEY_REQUEST_LIMITED="<your-request-limited-key>"
APIM_KEY_TOKEN_LIMITED="<your-token-limited-key>"

# ═══════════════════════════════════════════════════════
# Lab 4: Azure AD JWT 테스트용 (선택사항)
# ═══════════════════════════════════════════════════════

# JWT 인증 실습을 하려면 Azure AD에 앱을 등록해야 합니다.
# 경로: Azure Portal → Microsoft Entra ID (구 Azure AD) → 앱 등록
#       → + 새 등록 → 등록 후 아래 값 확인
# AZURE_TENANT_ID: 개요 → 디렉터리(테넌트) ID
# AZURE_CLIENT_ID: 개요 → 애플리케이션(클라이언트) ID
# AZURE_CLIENT_SECRET: 인증서 및 비밀 → + 새 클라이언트 비밀 → 값 복사
AZURE_TENANT_ID="<your-tenant-id>"
AZURE_CLIENT_ID="<your-client-id>"
AZURE_CLIENT_SECRET="<your-client-secret>"

# ═══════════════════════════════════════════════════════
# Lab 5: Gemini 설정 (선택사항)
# ═══════════════════════════════════════════════════════

# Google AI Studio에서 API Key를 발급받으세요.
# 경로: https://aistudio.google.com/apikey → Create API key
GEMINI_API_KEY="<your-gemini-api-key>"

# ═══════════════════════════════════════════════════════
# Lab 6: App Insights 쿼리용 (선택사항)
# ═══════════════════════════════════════════════════════

# 노트북에서 KQL을 프로그래밍 방식으로 조회할 때 사용합니다.
# Portal에서 직접 KQL을 실행한다면 이 설정 없이도 Lab 6 진행 가능합니다.
#
# 인증: Azure CLI 토큰을 사용하므로 API Key는 필요 없습니다 (az login만 되어 있으면 됨)
# APP_INSIGHTS_APP_ID만 설정하세요.
#
# 경로: Azure Portal → Application Insights → Overview → 상단 Essentials
#       "Application ID" 값이 아니라, Configure → API Access → Application ID 복사
#
# ⚠️ Overview의 "Instrumentation Key"나 "Connection string"과 다릅니다.
#    그것은 APIM이 데이터를 보내는 용도이고, 여기서는 데이터를 읽어오는 용도입니다.
APP_INSIGHTS_APP_ID="<your-app-insights-app-id>"
