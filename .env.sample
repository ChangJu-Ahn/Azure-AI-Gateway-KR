# ─── AI Gateway Lab 환경 변수 ───
# deploy.sh 실행 후 자동 생성됩니다 (.env 파일)
# Subscription Key만 수동 입력하세요.

# APIM 설정 (deploy.sh가 자동 입력)
APIM_URL=https://<apim-name>.azure-api.net
APIM_NAME=<apim-name>
RESOURCE_GROUP=rg-ai-gw-<suffix>

# APIM Subscription Key (수동 입력 필요)
# Azure Portal → API Management → Subscriptions → Built-in all-access subscription → Show/hide keys
APIM_SUBSCRIPTION_KEY="<your-subscription-key>"

# API 설정
DEPLOYMENT_NAME=gpt-4.1-nano
APIM_API_NAME=azure-openai-api

# 멀티 테넌트 테스트용 (Lab 4, 선택사항)
APIM_KEY_FREE="<free-tier-subscription-key>"
APIM_KEY_STANDARD="<standard-tier-subscription-key>"
APIM_KEY_PREMIUM="<premium-tier-subscription-key>"

# App Insights 쿼리용 (Lab 6, 선택사항)
APP_INSIGHTS_APP_ID="<your-app-insights-app-id>"
APP_INSIGHTS_API_KEY="<your-app-insights-api-key>"

# Gemini 설정 (Lab 5, 선택사항)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY="<your-gemini-api-key>"
